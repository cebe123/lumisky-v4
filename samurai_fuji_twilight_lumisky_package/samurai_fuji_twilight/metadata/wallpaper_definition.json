{
  "schemaVersion": 1,
  "id": "samurai_fuji_twilight",
  "name": "Samurai — Fuji Alacakaranlığı",
  "description": "Stilize Japon gün batımı, Fuji, samuray ve katmanlı dağ silüetlerinden oluşan statik zaman dilimi + parallax canlı duvar kâğıdı.",
  "category": "SCENIC_ANIME",
  "renderer": "StaticTimeSliceRenderer",
  "sourceType": "FULL_SCENE_STATIC_TIME_SLICES_WITH_OPTIONAL_LAYER_ASSETS",
  "selectedSkyStrategy": "STATIC_TIME_SLICE_MODE",
  "strategyReason": "Kaynak illüstrasyonun stilize bulutları, büyük güneş/dağ örtüşmesi ve tek flatten edilmiş raster kaynak nedeniyle ana runtime görsel doğruluğu altı FULL_SCENE time-slice texture ile korunur. Semantic PNG katmanları ayrı teslim edilir ve referans/sunset parallax profili ile isteğe bağlı kullanılabilir; ana crossfade hiçbir katman sınırı üretmez.",
  "canvas": {
    "width": 1440,
    "height": 2560,
    "aspectRatio": "9:16",
    "colorSpace": "sRGB",
    "orientation": "PORTRAIT"
  },
  "preview": {
    "thumbnail": "assets/preview/thumbnail.webp",
    "full": "assets/preview/full_preview.png",
    "composition": "assets/preview/composition_preview.png",
    "timeSlicePreviews": {
      "dawn": "assets/preview/composition_dawn.png",
      "noon": "assets/preview/composition_noon.png",
      "sunset": "assets/preview/composition_sunset.png",
      "moonrise": "assets/preview/composition_moonrise.png",
      "midnight": "assets/preview/composition_midnight.png",
      "moonset": "assets/preview/composition_moonset.png"
    }
  },
  "runtime": {
    "renderMode": "WHEN_DIRTY_WITH_PARALLAX_BURST",
    "liveWallpaper": {
      "normalMaxFps": 30,
      "batterySaverMaxFps": 15,
      "thermalSevereFpsRange": [
        8,
        15
      ],
      "idleContinuousRendering": false,
      "stopWhenInvisible": true,
      "timeUpdate": "MINUTE_TICK",
      "parallaxBurstDurationMs": 450
    },
    "catalogPreview": {
      "maxFps": 60,
      "activeRenderersWhileScrolling": 0,
      "activeRenderersAfterScroll": 1,
      "lowDeviceFps": 15,
      "midDeviceFps": 30,
      "highDeviceFps": 60
    },
    "fullscreenPreview": {
      "initialFps": 60,
      "adaptiveHighRefresh": true,
      "absoluteMaxFps": 120,
      "fastStepDownOnDeadlineMiss": true,
      "slowStepUpWhenStable": true
    },
    "textureResidency": {
      "timeSlicesResident": 2,
      "layerUploadMode": "CROP_TO_ALPHA_BOUNDS",
      "decodeDownsampleByQuality": true,
      "releaseOnInvisibleAfterMs": 15000
    },
    "alphaMode": "PREMULTIPLIED"
  },
  "locationAware": {
    "enabled": true,
    "optional": true,
    "permissionRequired": false,
    "fallbackSunriseMinutes": 360,
    "fallbackSunsetMinutes": 1080,
    "refreshPolicy": "ON_LOCATION_OR_TIMEZONE_CHANGE"
  },
  "timeModel": {
    "type": "LOCAL_SOLAR_FRACTION_WITH_STATIC_SLICE_ANCHORS",
    "dayProgressRange": [
      0.0,
      1.0
    ],
    "sunriseFractionSource": "sunriseMinutes/1440f",
    "sunsetFractionSource": "sunsetMinutes/1440f",
    "minuteTick": true,
    "cyclicAtMidnight": true,
    "moonPhaseSupported": true,
    "moonPhaseUsage": "Optional shader fallback and metadata-driven intensity; baked slice phases remain the visual source of truth."
  },
  "parallax": {
    "enabled": true,
    "coordinateSpace": "NORMALIZED_DEVICE_TILT",
    "directionRule": "FARTHER_MOVES_MORE",
    "verticalToHorizontalRatioMax": 0.45,
    "edgeProtection": "OVERSCAN_PLUS_INPAINTED_REVEAL_STRIP",
    "globalStrength": 1.0,
    "lowPassFilter": "EXPONENTIAL",
    "mode": "FULL_SCENE_UV_DEFAULT_WITH_OPTIONAL_SEMANTIC_REFERENCE_PROFILE",
    "defaultDuringCrossfade": "FULL_SCENE_UV_TRANSLATION_ONLY",
    "semanticLayerProfile": "Enable only when current/next slice is sunset and transition mix is outside 0.05..0.95, or after runtime mask-quality approval."
  },
  "shaders": {
    "primary": "shaders/gles3/sky_celestial_combined.frag",
    "vertex": "shaders/gles3/fullscreen.vert",
    "gles3": {
      "fullscreen.vert": "shaders/gles3/fullscreen.vert",
      "sky.frag": "shaders/gles3/sky.frag",
      "sun.frag": "shaders/gles3/sun.frag",
      "moon.frag": "shaders/gles3/moon.frag",
      "sky_celestial_combined.frag": "shaders/gles3/sky_celestial_combined.frag"
    },
    "gles2": {
      "fullscreen.vert": "shaders/gles2/fullscreen.vert",
      "sky.frag": "shaders/gles2/sky.frag",
      "sun.frag": "shaders/gles2/sun.frag",
      "moon.frag": "shaders/gles2/moon.frag",
      "sky_celestial_combined.frag": "shaders/gles2/sky_celestial_combined.frag"
    },
    "uniforms": [
      "u_Resolution",
      "u_DayProgress",
      "u_Sunrise",
      "u_Sunset",
      "u_TwilightWidth",
      "u_StarIntensity",
      "u_SunRadius",
      "u_SunGlowRadius",
      "u_SunIntensity",
      "u_MoonRadius",
      "u_MoonGlowRadius",
      "u_MoonIntensity",
      "u_MoonPhase",
      "u_Parallax",
      "u_SkyStyleMix",
      "u_CloudOpacity",
      "u_HorizonGlowIntensity",
      "u_ColorThemeMix"
    ],
    "mainUse": "Two-texture smoothstep crossfade; celestial shaders are fallback/debug paths."
  },
